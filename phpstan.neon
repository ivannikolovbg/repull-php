parameters:
  # The entire src/ tree is auto-generated by openapi-generator (php-nextgen).
  # Level 0 = parse-only — catches actual syntax breakage in generated code
  # without policing style/type-strictness choices made by the generator.
  # Hand-written wrapper code (when added) can move to a stricter level
  # via a separate paths section.
  level: 0
  paths:
    - src
